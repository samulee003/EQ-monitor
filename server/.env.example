# LINE Bot 配置
# 從 LINE Developers Console 獲取: https://developers.line.biz/
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# 服務端口
PORT=3000

# Supabase / InsForge PostgreSQL 連線
# 生產環境必須設定，否則會 fallback 到 memoryAdapter，重啟後資料全失
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ZEABUR AI Proxy (for backend proxy)
ZEABUR_AI_API_URL=https://api.zeabur.example/ai
ZEABUR_AI_API_KEY=your_zeabur_api_key_here
