        "pg": "^8.13.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/express": "^5.0.1",
        "@types/node": "^22.15.2",
        "@types/pg": "^8.11.10",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-istanbul": "^4.1.5",
        "@vitest/coverage-v8": "^4.1.5",
        "c8": "^11.0.0",
        "supertest": "^7.2.2",
        "tsx": "^4.19.3",
