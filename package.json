  "repository": {
    "type": "git",
    "url": "https://github.com/samulee003/EQ-monitor.git"
  },
  "homepage": "https://github.com/samulee003/EQ-monitor#readme",
  "bugs": {
    "url": "https://github.com/samulee003/EQ-monitor/issues"
  },
  "keywords": [
    "emotion",
    "mental-health",
    "emotional-awareness",
    "mindfulness",
    "react",
    "pwa",
    "typescript",
    "繁體中文"
  ],
  "engines": {
    "npm": ">=10",
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "cap:sync": "npm run build && npx cap copy && npx cap sync",
    "cap:open": "npx cap open android",
    "migrate": "tsx src/lib/insforge/migrate.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
